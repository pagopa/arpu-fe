{
  "name": "arpu-fe",
  "repository": "https://github.com/pagopa/arpu-fe",
  "author": "pagoPA",
  "license": "MIT",
  "source": "src/index.html",
  "scripts": {
    "generate-arpu-be-api-client": "swagger-typescript-api -p https://raw.githubusercontent.com/pagopa/arpu-be/refs/heads/develop/openapi/generated.openapi.json -o ./generated -n apiClient --axios",
    "generate-arpu-be-data-contracts": "swagger-typescript-api  --modular --no-client -p https://raw.githubusercontent.com/pagopa/arpu-be/refs/heads/develop/openapi/generated.openapi.json -o ./generated",
    "generate-checkout-api": "swagger-typescript-api -p https://raw.githubusercontent.com/pagopa/pagopa-api/master/openapi/checkout.json -o ./generated/checkout --axios --modular",
    "generate-zod-schema": "yarn ts-to-zod --all",
    "generate": "yarn generate-arpu-be-api-client && yarn generate-arpu-be-data-contracts && yarn generate-checkout-api && yarn generate-zod-schema",
    "lint": "eslint . -c .eslintrc.js --ext .ts,.tsx",
    "lint:fix": "eslint . -c .eslintrc.js --ext .ts,.tsx --fix",
    "format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
    "start": "yarn generate && parcel --no-cache --public-url /cittadini",
    "tscb": "tsc -p tsconfig.build.json",
    "build": "yarn generate && yarn tscb & parcel build --public-url /cittadini",
    "type-check": "tsc",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "serve-coverage-html-report": "npx serve coverage/lcov-report -c ./../../serve.json",
    "dependency-licenses": "license-checker --production --csv > dependency-licenses/licenses.csv"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.24.1",
    "@testing-library/react": "^14.3.0",
    "@types/license-checker": "^25",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@types/react-helmet": "^6",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitest/coverage-c8": "^0.33.0",
    "@vitest/coverage-v8": "^2.1.1",
    "@vitest/eslint-plugin": "^1.1.3",
